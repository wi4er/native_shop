<div class="product_card">
    <a
        href="/product/{{ slug }}/"
        title="{{ name }}"
        class="product_card_image"
    >
        <picture>
            <img
                src="{{ preview }}"
                alt="{{ name }}"
                title="{{ name }}"
            />
        </picture>
    </a>

    <a href="/product/{{ slug }}/" class="product_card_name">
        {{ name }}
    </a>

    <product-price
        class="product_buy"
        data-buy
        data-id="{{ id }}"
    >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
                d="M11 21C16.5228 21 21 16.5228 21 11C21 5.47715 16.5228 1 11 1C5.47715 1 1 5.47715 1 11C1 16.5228 5.47715 21 11 21Z"
                fill="#33907C"
                stroke="white"
            />
            <path d="M10.1246 8.41429H7V7H15V8.41429H11.8754V16H10.1246V8.41429Z" fill="white"/>
        </svg>

        <div class="product_price_button">
            Tradly
        </div>
    </product-price>

    <div class="product_price">
        <div class="product_price_discount">
            ${{ 35 }}
        </div>

        <div class="product_price_value">
            ${{ 25 }}
        </div>
    </div>
</div>
