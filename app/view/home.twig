{% extends "layout/common.twig" %}

{%  block body %}
    <div class="slider">
        <div class="slider_list">
            <div class="slider_item">
                <div class="slider_item_title">
                    Ready to deliver to your home
                </div>

                <div class="slider_item_button flex_center">
                    Start Shopping
                </div>
            </div>

            <div class="slider_item">
                <div class="slider_item_title">
                    Ready to deliver to your home
                </div>

                <div class="slider_item_button flex_center">
                    Start Shopping
                </div>
            </div>

            <div class="slider_item">
