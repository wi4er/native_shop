            style="background-image: url('{{ item.preview  }}')"
        >
            <a
                href="/catalog/{{ item.slug }}/"
                class="section_pale_text"
            >
                {{ item.name }}
            </a>
        </div>
    {% endfor %}
    </div>

    <div>
        <a href="/catalog/1/">
